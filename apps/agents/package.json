    "@langchain/langgraph": "^1.2.8",
    "@langchain/openai": "^1.4.3",
    "better-sqlite3": "^12.8.0",
    "deepagents": "^1.9.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "langchain": "^1.3.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@eslint/js": "^9.22.0",
    "@jest/globals": "^29.7.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
