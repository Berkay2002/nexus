{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/format-on-edit.mjs"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "wikillm@wikillm": false,
    "chrome-devtools-mcp@claude-plugins-official": true
  }
}