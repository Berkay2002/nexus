# Google Vertex AI (recommended)
# ADC activates Vertex mode. Run: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION="us-central1"

# Or, instead of Vertex ADC, a Gemini API key for Google AI Studio
GEMINI_API_KEY=""

# Search APIs
TAVILY_API_KEY=""
EXA_API_KEY=""

# AIO Sandbox
SANDBOX_URL="http://localhost:8080"

# LangGraph Frontend
NEXT_PUBLIC_API_URL="http://localhost:2024"
NEXT_PUBLIC_ASSISTANT_ID="nexus"

# LangSmith (optional — for tracing/debugging)
# LANGSMITH_API_KEY=""
# LANGSMITH_TRACING_V2="true"
# LANGSMITH_PROJECT="nexus"
