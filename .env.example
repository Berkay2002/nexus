# ─────────────────────────────────────────────────────────────────────────────
# Model providers — set at least one of the sections below.
# If multiple are set, Nexus picks providers by tier priority (see CLAUDE.md).
# Google is required for image generation (creative sub-agent).
# ─────────────────────────────────────────────────────────────────────────────

# Google Vertex AI (recommended)
# ADC activates Vertex mode. Run: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION="us-central1"

# Or, instead of Vertex ADC, a Gemini API key for Google AI Studio
GEMINI_API_KEY=""

# Anthropic (optional — enables Claude sub-agents)
ANTHROPIC_API_KEY=""

# OpenAI (optional — enables GPT sub-agents)
OPENAI_API_KEY=""

# Z.AI / GLM (optional — enables GLM-5.1 / GLM-5 Turbo / GLM-4.7).
# Get a key at https://z.ai/manage-apikey/apikey-list.
# Leave ZAI_BASE_URL unset for the standard pay-as-you-go API:
#   https://api.z.ai/api/paas/v4
# Or set it to the dedicated Coding endpoint if you're on the GLM Coding Plan:
#   ZAI_BASE_URL="https://api.z.ai/api/coding/paas/v4"
ZAI_API_KEY=""
# ZAI_BASE_URL=""

# Search APIs
TAVILY_API_KEY=""

# AIO Sandbox
SANDBOX_URL="http://localhost:8080"

# LangGraph Frontend
NEXT_PUBLIC_API_URL="http://localhost:2024"
NEXT_PUBLIC_ASSISTANT_ID="nexus"

# LangSmith (optional — for tracing/debugging)
# LANGSMITH_API_KEY=""
# LANGSMITH_TRACING_V2="true"
# LANGSMITH_PROJECT="nexus"
